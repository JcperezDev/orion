{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ORION",
  "version": "0.1.0",
  "identifier": "com.orion.agent",
  "build": {
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "ORION",
        "width": 1200,
        "height": 760,
        "minWidth": 800,
        "minHeight": 540,
        "center": true,
        "resizable": true,
        "maximizable": true,
        "minimizable": true,
        "closable": true,
        "decorations": false,
        "transparent": true,
        "visible": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [],
      "pubkey": "",
      "windows": {
        "installMode": "passive"
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb", "rpm", "appimage"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "binaries/orion-server"
    ],
    "category": "DeveloperTool",
    "shortDescription": "ORION — AI coding agent",
    "longDescription": "ORION is a multi-provider AI coding agent with a native desktop UI."
  }
}
