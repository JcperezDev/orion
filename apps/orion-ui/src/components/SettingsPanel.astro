---
// SettingsPanel.astro — read-only settings overview.
// The React SettingsPanel rendered 8 fully interactive sections (toggles,
// theme editor, MCP server form, permission cycle, etc.). The pure-Astro
// build exposes the same navigation surface as a static panel; mutations
// happen through the ORION core API and are written back to
// ~/.orion/settings.json by the server.
import {
  Settings as SettingsIcon,
  Plug,
  Globe,
  Palette,
  Keyboard,
  Server as ServerIcon,
  Brain,
  Lock,
} from 'lucide-astro';

const sections = [
  { id: 'general', label: 'General', icon: SettingsIcon, group: 'General', blurb: 'behavior, permissions, default shell' },
  { id: 'providers', label: 'Providers', icon: Plug, group: 'General', blurb: 'connected LLM providers and credentials' },
  { id: 'language', label: 'Language', icon: Globe, group: 'General', blurb: 'interface and agent response language' },
  { id: 'appearance', label: 'Appearance', icon: Palette, group: 'Interface', blurb: 'themes, color scheme, UI/code fonts' },
  { id: 'shortcuts', label: 'Shortcuts', icon: Keyboard, group: 'Interface', blurb: 'keyboard binding reference' },
  { id: 'servers', label: 'Servers', icon: ServerIcon, group: 'System', blurb: 'MCP server registry' },
  { id: 'memory', label: 'Memory', icon: Brain, group: 'System', blurb: 'project memory and token budget' },
  { id: 'permissions', label: 'Permissions', icon: Lock, group: 'System', blurb: 'per-action allow/ask/block policy' },
];

const groups: Array<'General' | 'Interface' | 'System'> = ['General', 'Interface', 'System'];
---
<div class="settings-shell">
  <nav class="settings-nav">
    <div class="settings-nav-top">
      <div>
        <div class="settings-nav-title">Settings</div>
        <div class="settings-nav-ver">Orion v2.0</div>
      </div>
    </div>
    {groups.map((g) => (
      <div>
        <div class="settings-nav-label">{g}</div>
        {sections
          .filter((s) => s.group === g)
          .map((s) => {
            const Icon = s.icon;
            return (
              <div class="settings-ni" data-section={s.id}>
                <i><Icon size={16} /></i>
                {s.label}
              </div>
            );
          })}
      </div>
    ))}
  </nav>

  <div class="settings-content">
    <div class="sh">Settings</div>
    <div class="sd">
      Read-only preview. To modify settings, use the ORION core API
      (<code>PUT /api/settings</code>) or edit <code>~/.orion/settings.json</code>
      directly — changes are picked up on the next request.
    </div>

    <div class="group">
      <h3>Available sections</h3>
      <ul class="settings-overview">
        {sections.map((s) => (
          <li>
            <strong>{s.label}</strong>
            <span class="muted">— {s.blurb}</span>
          </li>
        ))}
      </ul>
    </div>

    <div class="group">
      <h3>Live editing</h3>
      <p class="muted" style="font-size: 13px; margin: 0;">
        Interactive toggles, theme pickers, custom theme editor, and the
        MCP server form have been moved to the core API surface. The UI
        layer in this build is a read-only shell — server-side state stays
        the single source of truth and the browser stays free of editor
        state machinery.
      </p>
    </div>
  </div>
</div>

<style>
  .settings-overview {
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .settings-overview li {
    padding: 6px 0;
    font-size: 13px;
    border-bottom: 0.5px solid var(--color-border-tertiary);
  }
  .settings-overview li:last-child { border-bottom: none; }
  .settings-overview .muted { color: var(--color-text-tertiary); font-size: 12px; margin-left: 4px; }
</style>
